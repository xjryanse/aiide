{
  "name": "axsl-aiide",
  "displayName": "axsl-aiide",
  "description": "Lightweight coding agent (Python backend + VSCode webview).",
  "version": "0.1.0",
  "publisher": "axsl",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Machine Learning"],
  "activationEvents": [
    "onStartupFinished",
    "onView:axslAiide.chat",
    "onCommand:axslAiide.openChat",
    "onCommand:axslAiide.restartAgent",
    "onCommand:axslAiide.newSession"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "axslAiide.openChat",
        "title": "axsl-aiide: 打开聊天面板",
        "category": "axsl-aiide"
      },
      {
        "command": "axslAiide.restartAgent",
        "title": "axsl-aiide: 重启 Agent 后端",
        "category": "axsl-aiide"
      },
      {
        "command": "axslAiide.newSession",
        "title": "axsl-aiide: 新建会话",
        "category": "axsl-aiide"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "axslAiide",
          "title": "axsl-aiide",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "axslAiide": [
        {
          "id": "axslAiide.chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "axsl-aiide",
      "properties": {
        "axslAiide.agentBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8100",
          "description": "Python Agent 服务地址。为空/默认时,扩展会尝试自动启动本地进程。"
        },
        "axslAiide.autoStartAgent": {
          "type": "boolean",
          "default": true,
          "description": "扩展激活时自动 spawn 本地 Python Agent 服务。"
        },
        "axslAiide.agentDir": {
          "type": "string",
          "default": "",
          "description": "本地 axsl-aiide 的 agent/ 目录绝对路径(留空则相对扩展目录 ../agent)。"
        },
        "axslAiide.pythonPath": {
          "type": "string",
          "default": "",
          "description": "用于启动 Agent 的 Python 解释器(留空则用 agent/.venv 或系统 python)。"
        },
        "axslAiide.workspaceOverride": {
          "type": "string",
          "default": "",
          "description": "覆盖默认工作区路径(留空则用当前打开的 VSCode workspaceFolder)。"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=dist/extension.js",
    "watch": "npm run build -- --watch --sourcemap",
    "package": "npm run build -- --minify && vsce package",
    "vscode:prepublish": "npm run build -- --minify"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
