# === LLM 配置(OpenAI 兼容接口) ===
# 官方 OpenAI:  https://api.openai.com/v1
# DeepSeek:     https://api.deepseek.com/v1
# 通义:        https://dashscope.aliyuncs.com/compatible-mode/v1
# 本地 Ollama:  http://127.0.0.1:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# === Agent 运行参数 ===
AGENT_MAX_STEPS=20
AGENT_SHELL_TIMEOUT=60
AGENT_MAX_OUTPUT_CHARS=8000

# === Prompt Caching(可选) ===
# 走 Anthropic 官方 openai-compat 端点 / OpenRouter 调用 Claude 时,置 1 可显式启用
# system prompt 的前缀缓存(cache_control: ephemeral),命中后费用降低 ~90%。
# DeepSeek / OpenAI 官方 / 多数国内中转会忽略该字段,自身走自动前缀缓存,置 0 即可。
# 若开启后某些后端报 "invalid message content" 之类的 400,把它关掉。
AGENT_ANTHROPIC_CACHE=0

# 历史压缩阈值:tool 结果超过多少字符就折叠成一行摘要
AGENT_COMPRESS_ABOVE_CHARS=800
# 最近 N 条 tool 结果保持原样不压
AGENT_KEEP_RECENT_TOOL_RESULTS=3

# === 服务端口 ===
AGENT_HOST=127.0.0.1
AGENT_PORT=8100

# === 路径(相对项目根,一般不改) ===
WORKSPACE_DIR=../workspace
STORAGE_DIR=../storage
